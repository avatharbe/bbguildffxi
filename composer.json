{
  "name": "avathar/bbguild_ffxi",
  "type": "phpbb-extension",
  "description": "Final Fantasy XI game plugin for bbGuild. Provides FFXI classes, races, and factions.",
  "homepage": "https://github.com/avandenberghe/bbguild",
  "version": "2.0.0-a1",
  "time": "2026-03-02",
  "license": "GPL-2.0-only",
  "authors": [
    {
      "name": "Andreas Vandenberghe (Sajaki)",
      "email": "sajaki@avathar.be",
      "homepage": "https://www.avathar.be",
      "role": "Developer"
    }
  ],
  "require": {
    "php": ">=8.1",
    "composer/installers": "~1.0"
  },
  "extra": {
    "display-name": "bbGuild - Final Fantasy XI",
    "soft-require": {
      "phpbb/phpbb": ">=3.3.0,<3.4.0@dev",
      "avathar/bbguild": ">=2.0.0-a10"
    },
    "version-check": {
      "host": "www.avathar.be",
      "directory": "/versioncheck",
      "filename": "bbguild_ffxi.json",
      "ssl": true
    }
  }
}
